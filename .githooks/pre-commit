#!/bin/sh
# pre-commit hook: lint staged src/ JS/TS files with Biome.

set -eu

REPO_ROOT=$(git rev-parse --show-toplevel)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^src/.*\.(ts|tsx|js|jsx)$' || true)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

if [ -x "$REPO_ROOT/node_modules/.bin/biome" ]; then
  BIOME_CMD="$REPO_ROOT/node_modules/.bin/biome"
elif [ -x "$REPO_ROOT/node_modules/.bin/biome.exe" ]; then
  BIOME_CMD="$REPO_ROOT/node_modules/.bin/biome.exe"
elif command -v bunx >/dev/null 2>&1; then
  BIOME_CMD="bunx biome"
elif command -v npx >/dev/null 2>&1; then
  BIOME_CMD="npx biome"
else
  echo "Biome lint failed: could not find a Biome executable."
  echo "Install dependencies with 'bun install' before committing."
  exit 1
fi

echo "Running Biome lint on staged files..."

run_biome_lint() {
  file_path="$1"
  case "$BIOME_CMD" in
    "bunx biome")
      bunx biome lint --no-errors-on-unmatched --diagnostic-level=error "$file_path"
      ;;
    "npx biome")
      npx biome lint --no-errors-on-unmatched --diagnostic-level=error "$file_path"
      ;;
    *)
      "$BIOME_CMD" lint --no-errors-on-unmatched --diagnostic-level=error "$file_path"
      ;;
  esac
}

printf '%s\n' "$STAGED_FILES" | while IFS= read -r file; do
  [ -n "$file" ] || continue
  run_biome_lint "$file" || {
    echo ""
    echo "Biome lint failed. Fix errors or use --no-verify to bypass."
    exit 1
  }
done
